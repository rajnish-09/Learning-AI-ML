import pandas as pd


df = pd.read_csv("raw_data.csv")
# return true for null values
df.isnull()

# return number of null values
df.isnull().sum()

# drop row having at least a null value. (To drop col -> dropna(axis=1))
df.dropna()

# fill null value with a value
cleaned_data = df.copy()
age_mean = cleaned_data['age'].mean()
cleaned_data['age'] = cleaned_data['age'].fillna(age_mean)
cleaned_data

df.ffill()


df


# Handling duplicate values
# return true for duplicated row
df.duplicated()

# drop duplicate rows
df.drop_duplicates()


# Handling data types
df.dtypes

# to change the data type
df2 = df.copy()
df2 = df2.fillna(0)
df2['age'] = df2['age'].astype("int64").copy()
df2.dtypes



