import pandas as pd


# Creating DataFrame 
# 1. From dictionary 
info = {
    "Name" : ["Hari", "Shyam", "Gita"],
    "Gpa" : [3.12, 2.23, 3.7]
}
df = pd.DataFrame(info)
df

# Print row labels
print(df.index)
# Print cols labels
print(df.columns)

# 2. From list of lists
l1 = [["Rajnish", 23], ["Shyam", 24], ["Hari", 20]]
df = pd.DataFrame(l1, columns = ["Name", "Age"])
df



