import pandas as pd


# Series in Pandas
s = pd.Series([1, 2, 3, 4, 5])
print(s)

# Printing using index
print(s[1])

# Printing using label
s1 = pd.Series([20, 21, 22, 23, 24], index=["Ram", "Shyam", "Hari", "Sita", "Gita"])
print(s1)
print(s1['Shyam'])

# Vectorized operation in Series
s2 = pd.Series([11, 12, 13, 14, 15])
print(s + s2)

# Dropping value using index
changed_s2 = s2.drop(0)
print(changed_s2)



