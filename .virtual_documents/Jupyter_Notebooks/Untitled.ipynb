import numpy as np


# Creating numpy arrays
arr = np.array([1,2,3,4,5,6])
print(arr, type(arr))

# Creating array with scratch
# 1. With all zeros
arr = np.zeros((2,3))
print(arr)

# 2. With all ones
arr = np.ones((3,3))
print(arr)

# 3. Full with a value
arr = np.full((3,3), 22)
print(arr)

# 4. Create identity matrix
arr = np.eye(3)
print(arr)

# 5. With arange
arr = np.arange(1, 10, 2)
print(arr)

# 6. linspace -> To create evenly space array
arr = np.linspace(1,100,5)
print(arr)



# Numpy arrays properties
arr = np.array([[1,2,3], [4,5,6]])
print(arr.shape)




